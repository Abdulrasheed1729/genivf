[
  {
    "label": "Setup Meson",
    "command": "meson setup build",
  },
  {
    "label": "Build",
    "command": "meson compile -C build",
  },
  {
    "label": "Test",
    "command": "meson test -C build",
  },
  {
    "label": "Run",
    "command": "build/genivf",
  },
  {
    "label": "Run Tests",
    "command": "build/tests/genivf_test && build/tests/io_test && build/tests/point_test",
  },
  {
    "label": "Run examples",
    "command": "build/examples/simple",
  },
]
